# NOTE: no quotes around values — `docker run --env-file` takes lines
# verbatim, so quotes would become part of the value and break e.g. SMTP.

# How often (in minutes) to check for new invoices
POLLING_INTERVAL=15
# Also download subscription (e.g. Premium Connectivity) invoices
ENABLE_SUBSCRIPTION_INVOICE=True

# Optional: preferred dashboard currency (e.g. EUR); auto-detected when empty
DEFAULT_CURRENCY=
# Optional: web UI port inside the container (also adjust -p when changing)
#PORT=9000

# Optional: tokens directly via environment instead of the mounted secrets files
# (only REFRESH_TOKEN is required; the access token is obtained automatically)
ACCESS_TOKEN=
REFRESH_TOKEN=

# Email export: send each new invoice once as an email attachment
ENABLE_EMAIL_EXPORT=False
EMAIL_FROM=tesla-invoices@acme.org
EMAIL_TO=recipient@example.com
EMAIL_SERVER=mail.example.com
# 587 uses STARTTLS, 465 uses implicit TLS
EMAIL_SERVER_PORT=587
EMAIL_USER=emailuser@example.com
EMAIL_PASS=somesecretpassword!
